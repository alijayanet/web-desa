  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <h3 class="footer-logo-title"><%= settings.nama_desa || 'Desa Ujunggebang' %></h3>
        <p class="footer-text">
          Portal Desa Digital Modern untuk mempermudah pelayanan administrasi surat-menyurat, pengaduan warga, dan transparansi informasi publik desa secara terintegrasi.
        </p>
      </div>
      
      <div>
        <h4 class="footer-links-title">Menu Cepat</h4>
        <ul class="footer-menu">
          <li><a href="/">Beranda</a></li>
          <li><a href="/profil">Profil Desa</a></li>
          <li><a href="/berita">Berita & Kegiatan</a></li>
          <li><a href="/login">Login Portal</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="footer-links-title">Kontak Kantor Desa</h4>
        <ul class="footer-contact">
          <li>📍 <%= settings.alamat_kantor || 'Desa Ujunggebang, Kec. Sukra, Kab. Indramayu, Jawa Barat' %></li>
          <li>📞 <%= settings.telepon || '0812-3456-7890' %></li>
          <% 
            const waRaw = (settings.whatsapp || '').toString().replace(/[^0-9]/g, '');
            let waNum = waRaw;
            if (waNum.startsWith('0')) waNum = '62' + waNum.slice(1);
            else if (waNum.startsWith('8')) waNum = '62' + waNum;
          %>
          <% if (waNum) { %>
            <li>💬 <a href="https://wa.me/<%= waNum %>" target="_blank" rel="noopener noreferrer"><%= settings.whatsapp %></a></li>
          <% } %>
          <li>✉️ <%= settings.email || 'info@ujunggebang.desa.id' %></li>
        </ul>
      </div>
    </div>
    
    <div class="container footer-bottom">
      <p>&copy; 2026 <%= settings.nama_desa || 'Desa Ujunggebang' %>. Seluruh Hak Cipta Dilindungi. Aplikasi Desa Digital Modern.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
