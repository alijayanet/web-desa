<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Kabar &amp; Kegiatan <%= settings.nama_desa || 'Desa' %></h1>
      <p>Media informasi resmi, pengumuman publik, dan berita pembangunan kemasyarakatan <%= settings.nama_desa || 'Desa' %>.</p>
    </div>
  </section>

  <!-- News Section -->
  <section class="news-section" style="background: none; padding: 60px 0 100px 0;">
    <div class="container">
      
      <div class="news-grid">
        <% if (berita && berita.length > 0) { %>
          <% berita.forEach(function(item) { %>
            <div class="news-card">
              <!-- Foto Thumbnail -->
              <div class="news-img" style="position: relative; overflow: hidden; background: #0f172a; min-height: 180px;">
                <% if (item.gambar && item.gambar !== 'berita_default.jpg') { %>
                  <img src="/uploads/<%= item.gambar %>" alt="<%= item.judul %>" 
                    style="width: 100%; height: 180px; object-fit: cover; display: block; transition: transform 0.4s ease;"
                    onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                <% } else { %>
                  <div style="width: 100%; height: 180px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
                    <span style="font-size: 48px; opacity: 0.3;">📰</span>
                  </div>
                <% } %>
                <!-- Badge video jika ada embed -->
                <% if (item.embed_url && item.embed_url.trim() !== '') { %>
                  <div style="position: absolute; top: 10px; right: 10px; background: rgba(0,0,0,0.7); color: #fff; padding: 3px 8px; border-radius: 20px; font-size: 11px; font-weight: 700; display: flex; align-items: center; gap: 4px;">
                    🎬 Video
                  </div>
                <% } %>
              </div>
              <div class="news-body">
                <div class="news-meta">
                  <span>📅 <%= item.tanggal %></span>
                  <span>🏷️ <%= item.kategori %></span>
                </div>
                <h3><%= item.judul %></h3>
                <p><%= item.ringkasan %></p>
                <a href="/berita/<%= item.id %>" class="news-link">Selengkapnya &rarr;</a>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div style="grid-column: span 3; text-align: center; color: var(--text-muted); padding: 80px 0;">
            <div style="font-size: 48px; margin-bottom: 16px;">📰</div>
            <h3>Belum ada berita</h3>
            <p>Pemerintah Desa belum mengunggah berita atau pengumuman saat ini.</p>
          </div>
        <% } %>
      </div>
      
    </div>
  </section>

<%- include('partials/footer') %>
