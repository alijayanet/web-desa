<%- include('partials/header') %>

<main style="max-width: 1200px; margin: 40px auto; padding: 0 20px;">
  <div style="background: var(--grad-primary); border-radius: var(--radius-md); padding: 40px 28px; color: var(--white); box-shadow: 0 10px 30px rgba(14, 165, 233, 0.15); margin-bottom: 28px; position: relative; overflow: hidden;">
    <div style="position: relative; z-index: 2;">
      <span style="font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; background: rgba(255, 255, 255, 0.15); padding: 6px 16px; border-radius: 20px;">TRANSPARANSI KINERJA</span>
      <h1 style="color: var(--white); font-size: 30px; font-weight: 800; margin-top: 14px; margin-bottom: 8px;">Absensi Perangkat Desa</h1>
      <p style="opacity: 0.92; font-size: 14px; max-width: 850px; line-height: 1.6; margin: 0;">
        Rekap kehadiran harian perangkat desa <%= settings.nama_desa || 'Desa' %>. Warga dapat memantau jam masuk/pulang serta bukti foto absensi.
      </p>
    </div>
    <div style="position: absolute; right: -30px; bottom: -40px; font-size: 180px; opacity: 0.06; user-select: none;">🕒</div>
  </div>

  <div class="card-panel" style="padding: 18px; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-md); margin-bottom: 22px;">
    <form action="/absensi" method="GET" style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <div style="font-weight: 800;">Filter Tanggal</div>
      <input type="date" name="tanggal" value="<%= tanggal %>" class="form-control" style="max-width: 220px; padding: 8px 12px; font-size: 13px;">
      <button type="submit" class="btn btn-primary" style="padding: 10px 16px;">🔎 Tampilkan</button>
      <% if (user && user.role !== 'warga') { %>
        <a href="/dashboard/absensi" class="btn btn-secondary" style="padding: 10px 16px;">📷 Input Absensi</a>
      <% } %>
    </form>
  </div>

  <div class="card-panel" style="padding: 22px; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-md); margin-bottom: 26px;">
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; margin-bottom: 16px;">
      <div>
        <h3 style="font-size: 18px; font-weight: 800; margin: 0;">Rekap Kehadiran (<%= tanggal %>)</h3>
        <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">Menampilkan jam masuk (pertama) dan jam pulang (terakhir) pada tanggal tersebut.</div>
      </div>
      <input type="text" id="searchAbsensi" onkeyup="filterTable('searchAbsensi', 'tableAbsensiSummary')" placeholder="🔍 Cari nama/jabatan..." class="form-control" style="max-width: 260px; padding: 8px 12px; font-size: 13px;">
    </div>

    <div class="table-responsive">
      <table class="table-custom" id="tableAbsensiSummary" style="width: 100%;">
        <thead>
          <tr>
            <th>Nama</th>
            <th>Role</th>
            <th>Masuk</th>
            <th>Pulang</th>
            <th style="text-align: center;">Bukti Masuk</th>
            <th style="text-align: center;">Bukti Pulang</th>
          </tr>
        </thead>
        <tbody>
          <% if (summary && summary.length > 0) { %>
            <% summary.forEach(function(s) { %>
              <tr>
                <td style="font-weight: 800;"><%= s.nama %></td>
                <td style="text-transform: uppercase; font-size: 12px; font-weight: 700; color: var(--text-muted);"><%= s.role %></td>
                <td style="font-weight: 700;"><%= s.masuk_waktu ? new Date(s.masuk_waktu).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) : '-' %></td>
                <td style="font-weight: 700;"><%= s.pulang_waktu ? new Date(s.pulang_waktu).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) : '-' %></td>
                <td style="text-align: center;">
                  <% if (s.masuk_foto) { %>
                    <a href="<%= s.masuk_foto %>" target="_blank">
                      <img src="<%= s.masuk_foto %>" alt="Bukti Masuk" style="width: 44px; height: 44px; object-fit: cover; border-radius: 12px; border: 1px solid var(--border);">
                    </a>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td style="text-align: center;">
                  <% if (s.pulang_foto) { %>
                    <a href="<%= s.pulang_foto %>" target="_blank">
                      <img src="<%= s.pulang_foto %>" alt="Bukti Pulang" style="width: 44px; height: 44px; object-fit: cover; border-radius: 12px; border: 1px solid var(--border);">
                    </a>
                  <% } else { %>
                    -
                  <% } %>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 26px;">Belum ada data pegawai/absensi.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card-panel" style="padding: 22px; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-md);">
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; margin-bottom: 16px;">
      <div>
        <h3 style="font-size: 18px; font-weight: 800; margin: 0;">Log Absensi</h3>
        <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">Maksimal 300 data terbaru pada tanggal tersebut.</div>
      </div>
      <input type="text" id="searchAbsensiLog" onkeyup="filterTable('searchAbsensiLog', 'tableAbsensiLog')" placeholder="🔍 Cari nama/role/catatan..." class="form-control" style="max-width: 280px; padding: 8px 12px; font-size: 13px;">
    </div>

    <div class="table-responsive">
      <table class="table-custom" id="tableAbsensiLog" style="width: 100%;">
        <thead>
          <tr>
            <th>Waktu</th>
            <th>Nama</th>
            <th>Role</th>
            <th>Jenis</th>
            <th style="text-align: center;">Foto</th>
            <th>Catatan</th>
          </tr>
        </thead>
        <tbody>
          <% if (logs && logs.length > 0) { %>
            <% logs.forEach(function(l) { %>
              <tr>
                <td style="font-weight: 700;"><%= l.waktu ? new Date(l.waktu).toLocaleString('id-ID') : '-' %></td>
                <td style="font-weight: 800;"><%= l.nama %></td>
                <td style="text-transform: uppercase; font-size: 12px; font-weight: 700; color: var(--text-muted);"><%= l.role %></td>
                <td>
                  <% if (l.jenis === 'masuk') { %>
                    <span class="badge badge-success" style="font-size: 11px;">Masuk</span>
                  <% } else { %>
                    <span class="badge badge-pending" style="font-size: 11px;">Pulang</span>
                  <% } %>
                </td>
                <td style="text-align: center;">
                  <% if (l.foto) { %>
                    <a href="<%= l.foto %>" target="_blank">
                      <img src="<%= l.foto %>" alt="Foto" style="width: 44px; height: 44px; object-fit: cover; border-radius: 12px; border: 1px solid var(--border);">
                    </a>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td style="color: var(--text-muted);"><%= l.catatan || '-' %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 26px;">Belum ada absensi pada tanggal ini.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<script>
  function filterTable(inputId, tableId) {
    const input = document.getElementById(inputId);
    const table = document.getElementById(tableId);
    if (!input || !table) return;
    const filter = String(input.value || '').toLowerCase();
    const rows = table.getElementsByTagName('tr');
    for (let i = 1; i < rows.length; i++) {
      const row = rows[i];
      const text = row.textContent || row.innerText || '';
      row.style.display = text.toLowerCase().includes(filter) ? '' : 'none';
    }
  }
</script>

<%- include('partials/footer') %>
