<%- include('../partials/dashboard-header') %>

  <div class="card-panel" style="max-width: 900px; margin: 0 auto;">
    <div class="panel-header" style="flex-wrap: wrap; gap: 16px;">
      <h3>💬 Status WhatsApp Bot (Baileys)</h3>
      <div style="display: flex; gap: 10px; flex-wrap: wrap;">
        <button type="button" class="btn-sm btn-sm-secondary" onclick="checkStatus()" style="padding: 8px 14px;">🔄 Refresh</button>
        <form action="/dashboard/whatsapp/reset" method="POST" onsubmit="return confirm('Hapus sesi WhatsApp? Setelah ini harus scan QR ulang.');">
          <button type="submit" class="btn-sm btn-sm-danger" style="padding: 8px 14px;">🗑️ Reset Sesi</button>
        </form>
      </div>
    </div>

    <div class="card-panel" id="qr_section" style="display:none; margin-bottom: 18px; background: rgba(245, 158, 11, 0.04); border: 1px solid rgba(245, 158, 11, 0.18);">
      <div style="display:flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
        <div>
          <div style="font-size: 12px; color: var(--text-muted); font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Scan QR WhatsApp</div>
          <div style="font-size: 13px; font-weight: 800; margin-top: 6px;">Pindai QR ini dari WhatsApp untuk menghubungkan bot.</div>
        </div>
        <div style="font-size: 12px; color: var(--text-muted);"><strong>Terakhir update:</strong> <span id="wa_time_top">-</span></div>
      </div>
      <div id="qr_container" style="background:#fff; display:inline-block; padding: 14px; border-radius: 12px; border: 1px solid rgba(15,23,42,0.08); margin-top: 14px;"></div>
      <div style="font-size: 11px; color: var(--text-muted); margin-top: 8px;">QR akan berubah otomatis. Halaman ini refresh setiap 5 detik.</div>
    </div>

    <div class="card-panel" style="margin-bottom: 18px;">
      <div style="font-size: 12px; color: var(--text-muted); font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Penerima Notifikasi</div>
      <form action="/dashboard/whatsapp/settings" method="POST">
        <div class="form-group">
          <label for="whatsapp">NOMOR ADMIN (UTAMA)</label>
          <input type="text" id="whatsapp" name="whatsapp" value="<%= settings.whatsapp || '' %>" class="form-control" placeholder="Contoh: 62812xxxxxxx">
        </div>
        <div class="form-group">
          <label for="wa_recipients">NOMOR PENERIMA TAMBAHAN (STAFF/ADMIN)</label>
          <textarea id="wa_recipients" name="wa_recipients" rows="3" class="form-control" placeholder="Satu nomor per baris. Contoh: 62812xxxxxxx"><%= (settings.wa_recipients && settings.wa_recipients.length > 0) ? settings.wa_recipients.join('\n') : '' %></textarea>
          <div style="font-size: 11px; color: var(--text-muted); margin-top: 6px; line-height: 1.4;">Jika diisi, semua laporan/pengajuan via WhatsApp akan dikirim ke semua nomor di daftar ini.</div>
        </div>
        <button type="submit" class="btn-sm btn-sm-primary" style="padding: 10px 14px;">💾 Simpan Nomor</button>
        <a href="/dashboard/pengaturan" class="btn-sm btn-sm-secondary" style="padding: 10px 14px; margin-left: 8px; text-decoration:none;">⚙️ Buka Pengaturan</a>
      </form>
    </div>

    <div class="alert alert-danger" id="wa_error" style="display:none;">
      <span>⚠️</span>
      <div id="wa_error_text">-</div>
    </div>

    <div class="card-panel" style="background: rgba(14, 165, 233, 0.03); border: 1px solid rgba(14, 165, 233, 0.12);">
      <div style="display: flex; flex-wrap: wrap; gap: 14px; align-items: center; justify-content: space-between;">
        <div>
          <div style="font-size: 12px; color: var(--text-muted); font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Status</div>
          <div id="wa_status" style="font-size: 20px; font-weight: 900;">-</div>
          <div id="wa_desc" style="font-size: 12px; color: var(--text-muted); margin-top: 6px;">-</div>
        </div>
        <div style="display:flex; gap:10px; align-items:center; flex-wrap: wrap;">
          <div style="font-size: 12px; color: var(--text-muted);">
            <div><strong>WhatsApp Admin:</strong> <%= settings.whatsapp || '-' %></div>
            <div><strong>Terakhir update:</strong> <span id="wa_time">-</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function setError(text) {
      const box = document.getElementById('wa_error');
      const el = document.getElementById('wa_error_text');
      if (!box || !el) return;
      if (!text) {
        box.style.display = 'none';
        el.innerText = '-';
        return;
      }
      el.innerText = String(text);
      box.style.display = 'flex';
    }

    async function checkStatus() {
      try {
        const res = await fetch('/dashboard/api/whatsapp/status');
        if (!res.ok) {
          setError('Gagal mengambil status WhatsApp.');
          return;
        }
        const s = await res.json();
        setError('');

        const statusEl = document.getElementById('wa_status');
        const descEl = document.getElementById('wa_desc');
        const timeEl = document.getElementById('wa_time');
        const timeTopEl = document.getElementById('wa_time_top');
        const qrSection = document.getElementById('qr_section');
        const qrContainer = document.getElementById('qr_container');

        const formattedTime = s.lastUpdate ? new Date(s.lastUpdate).toLocaleString('id-ID') : '-';
        if (timeEl) timeEl.innerText = formattedTime;
        if (timeTopEl) timeTopEl.innerText = formattedTime;

        if (!s.enabled) {
          if (statusEl) statusEl.innerText = 'Nonaktif';
          if (descEl) descEl.innerText = 'Set WA_BOT_ENABLED=1 untuk mengaktifkan bot.';
          if (qrSection) qrSection.style.display = 'none';
          return;
        }

        if (s.connection === 'missing_dependency') {
          if (statusEl) statusEl.innerText = 'Dependency belum ada';
          if (descEl) descEl.innerText = 'Jalankan npm install untuk memasang Baileys.';
          if (qrSection) qrSection.style.display = 'none';
          return;
        }

        if (s.connection === 'open') {
          if (statusEl) statusEl.innerText = 'Terhubung';
          if (descEl) descEl.innerText = 'WhatsApp bot aktif dan siap kirim notifikasi.';
          if (qrSection) qrSection.style.display = 'none';
          return;
        }

        if (s.connection === 'qr' && s.qr) {
          if (statusEl) statusEl.innerText = 'Perlu Scan QR';
          if (descEl) descEl.innerText = 'Scan QR ini melalui aplikasi WhatsApp.';
          if (qrSection) qrSection.style.display = 'block';
          if (qrContainer) {
            const ts = Date.now();
            qrContainer.innerHTML =
              '<img src="/dashboard/api/whatsapp/qr.png?ts=' + ts + '" alt="QR WhatsApp" style="width:256px;height:256px;display:block" />';
          }
          return;
        }

        if (statusEl) statusEl.innerText = 'Terputus';
        if (descEl) descEl.innerText = 'Bot belum terhubung atau sedang reconnect.';
        if (qrSection) qrSection.style.display = 'none';
      } catch (e) {
        setError('Error saat cek status WhatsApp.');
      }
    }

    checkStatus();
    setInterval(checkStatus, 5000);
  </script>

<%- include('../partials/dashboard-footer') %>
